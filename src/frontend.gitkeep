<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Acme HR Assistant</title>
<style>
  :root {
    --ink: #1a2233;
    --muted: #5b6678;
    --line: #e2e6ec;
    --bg: #f7f8fa;
    --card: #ffffff;
    --accent: #2f6df0;
    --accent-soft: #eaf1fe;
    --cite: #0f7a52;
    --cite-soft: #e7f5ee;
    --warn: #b4530a;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.55;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    padding: 32px 16px;
  }
  .wrap { width: 100%; max-width: 680px; }

  header { margin-bottom: 24px; }
  .badge {
    display: inline-block;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 10px;
    border-radius: 999px;
    font-weight: 600;
  }
  h1 { font-size: 26px; margin: 12px 0 4px; letter-spacing: -.01em; }
  .sub { color: var(--muted); font-size: 15px; }

  .ask {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 16px;
    box-shadow: 0 1px 2px rgba(16,24,40,.04);
  }
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 12px 14px;
    font: inherit;
    resize: vertical;
    min-height: 64px;
    color: var(--ink);
  }
  textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
  .row { display: flex; gap: 10px; align-items: center; margin-top: 12px; }
  button {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 11px 20px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  button:hover { background: #2459c9; }
  button:disabled { background: #9db8ef; cursor: not-allowed; }
  .hint { color: var(--muted); font-size: 13px; }

  .examples { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
  }
  .chip:hover { background: var(--accent-soft); }

  .answer {
    margin-top: 20px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 18px;
    display: none;
  }
  .answer.show { display: block; }
  .answer-label {
    font-size: 12px; letter-spacing: .06em; text-transform: uppercase;
    color: var(--muted); font-weight: 600; margin-bottom: 8px;
  }
  .answer-text { font-size: 16px; white-space: pre-wrap; }

  .mode-tag {
    float: right; font-size: 11px; font-weight: 600;
    padding: 2px 8px; border-radius: 999px;
  }
  .mode-mock { background: #fdf0e3; color: var(--warn); }
  .mode-live { background: var(--cite-soft); color: var(--cite); }

  .citations { margin-top: 16px; border-top: 1px solid var(--line); padding-top: 14px; }
  .citations h3 {
    font-size: 12px; letter-spacing: .06em; text-transform: uppercase;
    color: var(--cite); margin-bottom: 10px; font-weight: 700;
  }
  .cite {
    background: var(--cite-soft);
    border-left: 3px solid var(--cite);
    border-radius: 0 8px 8px 0;
    padding: 8px 12px;
    margin-bottom: 8px;
    font-size: 14px;
  }
  .cite .src { font-weight: 600; color: var(--cite); font-size: 13px; }
  .cite .snip { color: var(--muted); font-size: 13px; margin-top: 2px; }

  .error {
    margin-top: 20px; background: #fdecec; border: 1px solid #f5c2c2;
    color: #9b2226; border-radius: 12px; padding: 14px 16px;
    display: none; font-size: 14px;
  }
  .error.show { display: block; }

  .spinner {
    display: inline-block; width: 16px; height: 16px;
    border: 2px solid #fff; border-top-color: transparent;
    border-radius: 50%; animation: spin .7s linear infinite;
    vertical-align: -3px; margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .spinner { animation: none; } }

  footer { margin-top: 28px; text-align: center; color: var(--muted); font-size: 13px; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <span class="badge">Acme Corp · Internal</span>
    <h1>HR Policy Assistant</h1>
    <p class="sub">Ask about vacation, remote work, expenses, or the code of conduct. Answers come from the official policy documents, with sources.</p>
  </header>

  <section class="ask">
    <textarea id="q" placeholder="e.g. How many vacation days do I get in my first year?"></textarea>
    <div class="row">
      <button id="send">Ask</button>
      <span class="hint">Press Enter to send · Shift+Enter for a new line</span>
    </div>
    <div class="examples" id="examples">
      <button class="chip">How many vacation days in my first year?</button>
      <button class="chip">Can I expense internet while working remotely?</button>
      <button class="chip">What is a bridge day?</button>
    </div>
  </section>

  <div class="error" id="error"></div>

  <article class="answer" id="answer">
    <div class="answer-label">Answer <span class="mode-tag" id="mode"></span></div>
    <div class="answer-text" id="answerText"></div>
    <div class="citations" id="citations" style="display:none">
      <h3>Sources</h3>
      <div id="citeList"></div>
    </div>
  </article>

  <footer>Powered by Amazon Bedrock · RAG over internal documents</footer>
</div>

<script>
  // The ONLY thing this page knows about the backend: the API endpoint.
  // Replace with your API Gateway Invoke URL + /query.
  const API_URL = "https://rds5db2hm9.execute-api.us-east-1.amazonaws.com/query";

  const q = document.getElementById("q");
  const sendBtn = document.getElementById("send");
  const answerBox = document.getElementById("answer");
  const answerText = document.getElementById("answerText");
  const modeTag = document.getElementById("mode");
  const citationsBox = document.getElementById("citations");
  const citeList = document.getElementById("citeList");
  const errorBox = document.getElementById("error");

  function setLoading(on) {
    sendBtn.disabled = on;
    sendBtn.innerHTML = on ? '<span class="spinner"></span>Asking…' : "Ask";
  }

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.classList.add("show");
    answerBox.classList.remove("show");
  }

  function render(data) {
    errorBox.classList.remove("show");
    answerText.textContent = data.answer || "(no answer returned)";
    modeTag.textContent = data.mode === "live" ? "live" : "mock";
    modeTag.className = "mode-tag " + (data.mode === "live" ? "mode-live" : "mode-mock");

    citeList.innerHTML = "";
    const cites = data.citations || [];
    if (cites.length) {
      cites.forEach(c => {
        const div = document.createElement("div");
        div.className = "cite";
        const src = document.createElement("div");
        src.className = "src";
        src.textContent = c.source || "unknown source";
        div.appendChild(src);
        if (c.snippet) {
          const snip = document.createElement("div");
          snip.className = "snip";
          snip.textContent = c.snippet;
          div.appendChild(snip);
        }
        citeList.appendChild(div);
      });
      citationsBox.style.display = "block";
    } else {
      citationsBox.style.display = "none";
    }
    answerBox.classList.add("show");
  }

  async function ask() {
    const question = q.value.trim();
    if (!question) { showError("Type a question first."); return; }
    setLoading(true);
    try {
      const res = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question })
      });
      const data = await res.json();
      if (!res.ok) {
        showError(data.error || ("Request failed (HTTP " + res.status + ")."));
      } else {
        render(data);
      }
    } catch (e) {
      showError("Could not reach the assistant. Check your connection and try again.");
    } finally {
      setLoading(false);
    }
  }

  sendBtn.addEventListener("click", ask);
  q.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); ask(); }
  });
  document.getElementById("examples").addEventListener("click", e => {
    if (e.target.classList.contains("chip")) { q.value = e.target.textContent; ask(); }
  });
</script>
</body>
</html>
